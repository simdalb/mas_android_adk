# Copy this to .env and fill with your real values.
# Never commit the real .env file.

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Google / Gemini
GOOGLE_API_KEY=
GEMINI_API_KEY=

# App identity
APP_DISPLAY_NAME=LinkSaver
ANDROID_APP_NAME=LinkSaver
GOOGLE_PLAY_PACKAGE_NAME=com.example.linksaver

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_USE_AUTH=true
FIREBASE_USE_FIRESTORE=true
FIREBASE_USE_STORAGE=true
FIREBASE_USE_FUNCTIONS=true
FIREBASE_USE_ANALYTICS=true
FIREBASE_USE_CRASHLYTICS=true

# Google Play Billing
BILLING_PREMIUM_SUBSCRIPTION_ID=premium_monthly
BILLING_REMOVE_ADS_PRODUCT_ID=remove_ads

# AdMob
ADMOB_APP_ID=
ADMOB_BANNER_AD_UNIT_ID=
ADMOB_INTERSTITIAL_AD_UNIT_ID=
ADMOB_REWARDED_AD_UNIT_ID=
ADMOB_APP_OPEN_AD_UNIT_ID=
